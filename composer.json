{
  "name": "mugiew/starter-kit",
  "description": "Minimal Starterkit MVC Architecture for PHP Native",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.5",
    "ext-memcached": "*",
    "ext-pdo": "*",
    "ext-session": "*",
    "predis/predis": "^3.4",
    "guzzlehttp/guzzle": "^7.10",
    "vlucas/phpdotenv": "^5.6",
    "illuminate/database": "^12.0",
    "illuminate/events": "^12.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.0",
    "fakerphp/faker": "^1.24"
  },
  "autoload": {
    "psr-4": {
      "Mugiew\\StarterKit\\": "app/",
      "Mugiew\\StarterKit\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Mugiew\\StarterKit\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test:all": "vendor/bin/phpunit",
    "migrate": "@php bin/console migrate",
    "migrate:fresh": "@php bin/console migrate:fresh",
    "migrate:fresh:seed": "@php bin/console migrate:fresh --seed",
    "seed": "@php bin/console seed"
  },
  "authors": [
    {
      "name": "Mugiew Galeano"
    }
  ]
}
