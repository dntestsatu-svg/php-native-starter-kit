APP_NAME=NativeStarter
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=en
APP_FAKER_LOCALE=en_US

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=native
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_COOKIE=native_session
SESSION_PREFIX=native_session:
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Lax
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=memcached
CACHE_PREFIX=native
CACHE_DEFAULT_TTL=300
CACHE_ENV_TTL=600
CACHE_CONFIG_TTL=600

MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211
MEMCACHED_WEIGHT=100
MEMCACHED_PERSISTENT_ID=null
MEMCACHED_TIMEOUT=1
MEMCACHED_RETRY_INTERVAL=2

REDIS_SCHEME=tcp
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_TIMEOUT=5

CSRF_ENABLED=true
CSRF_TOKEN_FIELD=_token
CSRF_HEADER=X-CSRF-TOKEN
CSRF_TTL=7200
CSRF_PREFIX=native_csrf:
CSRF_EXCEPT=/health

OTOMATIS_BASE_URL=
OTOMATIS_CLIENT=
OTOMATIS_CLIENT_KEY=
OTOMATIS_MERCHANT_UUID=
OTOMATIS_TIMEOUT=15
